{
    "version": "2.0.0",
    "inputs": [
        {
            "id": "configuration",
            "type": "promptString",
            "description": "Configuration name ('auto' for auto-detect, 'all' for all configurations, or specific config name)",
            "default": "auto"
        },
        {
            "id": "targetIP",
            "type": "promptString",
            "description": "Target IP address for transfer",
            "default": "127.0.0.1"
        },
        {
            "id": "silenceOutput",
            "type": "pickString",
            "description": "Silence info and warnings? (Only select 'no' when you want to see full build output)",
            "options": ["yes", "no"],
            "default": "yes"
        }
    
    ],
    "tasks": [
        {
            "label": "AS: Build",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}/.vscode/scripts/invoke-as-build.ps1",
                "-ProjectPath", "${workspaceFolder}",
                "-Action", "Build"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": [
                {
                    "owner": "as-build",
                    "fileLocation": ["absolute"],
                    "pattern": {
                        "regexp": "^(.*)\\((\\d+)\\):\\s+(error|warning)\\s+(\\d+):\\s+(.*)$",
                        "file": 1,
                        "line": 2,
                        "severity": 3,
                        "code": 4,
                        "message": 5
                    }
                },
                {
                    "owner": "as-build-warnings",
                    "fileLocation": ["absolute"],
                    "pattern": {
                        "regexp": "^(.*):\\s+\\(Ln:\\s+(\\d+)\\)\\s+(error|warning)\\s+(\\d+):(.*)$",
                        "file": 1,
                        "line": 2,
                        "severity": 3,
                        "code": 4,
                        "message": 5
                    }
                }
            ],
            "detail": "Build project (silent mode - shows only errors)"
        },
        {
            "label": "AS: Build All Configurations",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}/.vscode/scripts/invoke-as-build.ps1",
                "-ProjectPath", "${workspaceFolder}",
                "-Action", "Build",
                "-Configuration", "all"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": [
                {
                    "owner": "as-build",
                    "fileLocation": ["absolute"],
                    "pattern": {
                        "regexp": "^(.*)\\((\\d+)\\):\\s+(error|warning)\\s+(\\d+):\\s+(.*)$",
                        "file": 1,
                        "line": 2,
                        "severity": 3,
                        "code": 4,
                        "message": 5
                    }
                },
                {
                    "owner": "as-build-warnings",
                    "fileLocation": ["absolute"],
                    "pattern": {
                        "regexp": "^(.*):\\s+\\(Ln:\\s+(\\d+)\\)\\s+(error|warning)\\s+(\\d+):(.*)$",
                        "file": 1,
                        "line": 2,
                        "severity": 3,
                        "code": 4,
                        "message": 5
                    }
                }
            ],
            "detail": "Build all configurations (shows only errors)"
        },
        {
            "label": "AS: Rebuild",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}/.vscode/scripts/invoke-as-build.ps1",
                "-ProjectPath", "${workspaceFolder}",
                "-Action", "Rebuild"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": [
                {
                    "owner": "as-build",
                    "fileLocation": ["absolute"],
                    "pattern": {
                        "regexp": "^(.*)\\((\\d+)\\):\\s+(error|warning)\\s+(\\d+):\\s+(.*)$",
                        "file": 1,
                        "line": 2,
                        "severity": 3,
                        "code": 4,
                        "message": 5
                    }
                },
                {
                    "owner": "as-build-warnings",
                    "fileLocation": ["absolute"],
                    "pattern": {
                        "regexp": "^(.*):\\s+\\(Ln:\\s+(\\d+)\\)\\s+(error|warning)\\s+(\\d+):(.*)$",
                        "file": 1,
                        "line": 2,
                        "severity": 3,
                        "code": 4,
                        "message": 5
                    }
                }
            ],
            "detail": "Force complete rebuild (shows only errors)"
        },
        {
            "label": "AS: Clean",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}/.vscode/scripts/invoke-as-build.ps1",
                "-ProjectPath", "${workspaceFolder}",
                "-Action", "Clean"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": [],
            "detail": "Clean all build artifacts (Temp, Binaries)"
        },
        {
            "label": "AS: Transfer",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}/.vscode/scripts/invoke-as-build.ps1",
                "-ProjectPath", "${workspaceFolder}",
                "-Action", "Transfer",
                "-TargetIP", "127.0.0.1"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": [],
            "detail": "Transfer to localhost/ARsim (auto-generates PIL)"
        },
        {
            "label": "AS: Build and Transfer",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}/.vscode/scripts/invoke-as-build.ps1",
                "-ProjectPath", "${workspaceFolder}",
                "-Action", "BuildAndTransfer",
                "-TargetIP", "127.0.0.1"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": [
                {
                    "owner": "as-build",
                    "fileLocation": ["absolute"],
                    "pattern": {
                        "regexp": "^(.*)\\((\\d+)\\):\\s+(error|warning)\\s+(\\d+):\\s+(.*)$",
                        "file": 1,
                        "line": 2,
                        "severity": 3,
                        "code": 4,
                        "message": 5
                    }
                },
                {
                    "owner": "as-build-warnings",
                    "fileLocation": ["absolute"],
                    "pattern": {
                        "regexp": "^(.*):\\s+\\(Ln:\\s+(\\d+)\\)\\s+(error|warning)\\s+(\\d+):(.*)$",
                        "file": 1,
                        "line": 2,
                        "severity": 3,
                        "code": 4,
                        "message": 5
                    }
                }
            ],
            "detail": "Build and transfer to localhost/ARsim (shows only errors)"
        },
        {
            "label": "AS: Build (Interactive)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}/.vscode/scripts/invoke-as-build.ps1",
                "-ProjectPath", "${workspaceFolder}",
                "-Action", "Build",
                "-SilenceOutput", "${input:silenceOutput}",
                "-Configuration", "${input:configuration}"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": [
                {
                    "owner": "as-build",
                    "fileLocation": ["absolute"],
                    "pattern": {
                        "regexp": "^(.*)\\((\\d+)\\):\\s+(error|warning)\\s+(\\d+):\\s+(.*)$",
                        "file": 1,
                        "line": 2,
                        "severity": 3,
                        "code": 4,
                        "message": 5
                    }
                },
                {
                    "owner": "as-build-warnings",
                    "fileLocation": ["absolute"],
                    "pattern": {
                        "regexp": "^(.*):\\s+\\(Ln:\\s+(\\d+)\\)\\s+(error|warning)\\s+(\\d+):(.*)$",
                        "file": 1,
                        "line": 2,
                        "severity": 3,
                        "code": 4,
                        "message": 5
                    }
                }
            ],
            "detail": "Build with options. Use 'auto' for auto-detect, specific config name, or 'all' for all configurations."
        },
        {
            "label": "AS: Transfer (Interactive)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}/.vscode/scripts/invoke-as-build.ps1",
                "-ProjectPath", "${workspaceFolder}",
                "-Action", "Transfer",
                "-TargetIP", "${input:targetIP}"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": [],
            "detail": "Transfer with prompt for target IP"
        },
        {
            "label": "AS: Build and Transfer (Interactive)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}/.vscode/scripts/invoke-as-build.ps1",
                "-ProjectPath", "${workspaceFolder}",
                "-Action", "BuildAndTransfer",
                "-TargetIP", "${input:targetIP}",
                "-SilenceOutput", "${input:silenceOutput}",
                "-Configuration", "${input:configuration}"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": [
                {
                    "owner": "as-build",
                    "fileLocation": ["absolute"],
                    "pattern": {
                        "regexp": "^(.*)\\((\\d+)\\):\\s+(error|warning)\\s+(\\d+):\\s+(.*)$",
                        "file": 1,
                        "line": 2,
                        "severity": 3,
                        "code": 4,
                        "message": 5
                    }
                },
                {
                    "owner": "as-build-warnings",
                    "fileLocation": ["absolute"],
                    "pattern": {
                        "regexp": "^(.*):\\s+\\(Ln:\\s+(\\d+)\\)\\s+(error|warning)\\s+(\\d+):(.*)$",
                        "file": 1,
                        "line": 2,
                        "severity": 3,
                        "code": 4,
                        "message": 5
                    }
                }
            ],
            "detail": "Build and transfer with options. Use 'auto' for auto-detect, specific config name, or 'all' for all configurations."
        }
    ]
}
